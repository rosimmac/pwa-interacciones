{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "./test/.+\\.e2e-spec\\.ts$",
  "testPathIgnorePatterns": ["/node_modules/", "/src/"],
  "modulePaths": ["<rootDir>"],
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", {
      "tsconfig": "<rootDir>/tsconfig.json"
    }]
  }
}
